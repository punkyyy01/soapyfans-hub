# ── Supabase — obligatorio ────────────────────────────────────────────────────
# URL de tu proyecto Supabase.
# Obtenerla en: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clave anónima (pública). Es segura gracias a las políticas de Row Level Security.
# Obtenerla en: Supabase Dashboard → Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Service role key — acceso total a la base de datos, bypasea RLS completamente.
# Se usa solo en server actions y rutas de administración.
# ⚠️ NUNCA exponerla al cliente ni commitearla. Mantenerla solo en Vercel + .env.local.
# Obtenerla en: Supabase Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── TMDB — obligatorio ────────────────────────────────────────────────────────
# API key de The Movie Database para buscar películas y series.
# Obtenerla en: https://www.themoviedb.org/settings/api
# El plan gratuito es suficiente.
TMDB_API_KEY=

# ── URL del sitio — recomendado ───────────────────────────────────────────────
# URL canónica del sitio. Se usa para Open Graph, sitemaps y redirects.
# En desarrollo local: http://localhost:3000
# En producción: https://soapyhub.fans
NEXT_PUBLIC_SITE_URL=https://soapyhub.fans

# ── Variables auto-inyectadas por Vercel — no configurar manualmente ──────────
# Las siguientes las pone Vercel automáticamente en cada deploy.
# No hace falta agregarlas al .env.local ni al dashboard de Vercel.
# VERCEL_URL=          (URL del deploy actual, sin protocolo)
# VERCEL_PROJECT_PRODUCTION_URL=  (URL de producción del proyecto)
